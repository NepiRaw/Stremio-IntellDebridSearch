# Example environment configuration for Stremio DebridSearch Addon
# Copy this file to .env and fill in your API keys as fallbacks

# Optional API Keys (used as fallbacks when users don't provide them)
# These enhance search accuracy but are not required for basic functionality

# Trakt API Key - improves episode matching for non-standard numbering
# Get from: https://trakt.tv/oauth/applications
TRAKT_API_KEY=your_trakt_api_key_here

# TMDb API Key - enhances title matching for international/alternate titles  
# Get from: https://developer.themoviedb.org/docs/authentication
TMDB_API_KEY=your_tmdb_api_key_here

# Optional: Base addon URL (auto-detected if not provided)
ADDON_URL=http://127.0.0.1:55771
