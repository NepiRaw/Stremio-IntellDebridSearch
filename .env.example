# Example environment configuration for Stremio DebridSearch Addon
# Copy this file to .env and fill in your API keys as fallbacks

# Trakt API Key - improves episode matching for non-standard numbering - OPTIONAL
# Get from: https://trakt.tv/oauth/applications
# Example: TRAKT_API_KEY=your_trakt_api_key_here
TRAKT_API_KEY=

# TMDb API Key - enhances title matching for international/alternate titles - OPTIONAL - HIGHLY RECOMMENDED
# Get from: https://developer.themoviedb.org/docs/authentication
# Example: TMDB_API_KEY=your_tmdb_api_key_here
TMDB_API_KEY=

# Catalog Posters - OPTIONAL
# When 'true': attempts to enrich catalog items with TMDb posters for strong matches only
# When 'false': keeps the existing catalog behavior with no posters
# Default is 'false' for faster results
ENABLE_CATALOG_POSTERS=false

# Persistent Catalog Enrichment Cache - OPTIONAL
# Persists accepted/rejected poster resolution and metadata enrichment across restarts.
# Uses SQLite with filename aliases so the same release can hit cache across users/providers.
CATALOG_ENRICHMENT_CACHE_ENABLED=true
CATALOG_ENRICHMENT_CACHE_DB_PATH=./data/catalog-enrichment-cache.sqlite
CATALOG_ENRICHMENT_RESOLUTION_POSITIVE_TTL_DAYS=14
CATALOG_ENRICHMENT_RESOLUTION_NEGATIVE_TTL_HOURS=12
CATALOG_ENRICHMENT_METADATA_POSITIVE_TTL_HOURS=48
CATALOG_ENRICHMENT_METADATA_NEGATIVE_TTL_HOURS=6
CATALOG_ENRICHMENT_METADATA_SUSPECT_TTL_HOURS=12
CATALOG_ENRICHMENT_CACHE_CLEANUP_INTERVAL_SECONDS=21600
CATALOG_ENRICHMENT_CACHE_WAL_SIZE_LIMIT_MB=32
CATALOG_ENRICHMENT_CACHE_MAX_DB_MB=0 # 0 disables DB-size pruning (default). Set e.g. 256 to enable a 256MB soft limit for DB.
CATALOG_ENRICHMENT_CACHE_PRUNE_BATCH_SIZE=100

# Variant Detection System - enables detection of content variants (Directors Cut, Extended Edition, etc.) - OPTIONAL
# If enabled, it will display flagged variant. If disabled, nothing will be flagged.
# NB: Not 100% accurate, could be false or misleading if the content is not a variant, but nothing to lose to enable it.
# Set to 'false' to disable variant detection if needed
# Default is 'true' to enable variant detection
VARIANT_SYSTEM_ENABLED=true

# Multi-Stream Per Torrent Control - controls stream processing behavior - OPTIONAL
# When 'true': Allows multiple streams per torrent container (a bit slower but could return more results)
# When 'false': Forces single stream per torrent for ultra-fast performance (recommended default)
# Default is 'false' for optimal performance
ENABLE_MULTI_STREAM_PER_TORRENT=false

# Release Group Processing - controls release group extraction and display - OPTIONAL
# When 'true': Extracts and displays release groups in stream titles (e.g., "👥 [RARBG]")
# When 'false': Skips release group processing for improved performance
# Note: Disabling could improve processing time during metadata extraction
# Default is 'false'
ENABLE_RELEASE_GROUP=false

# Base URL for the addon - OPTIONAL
# Complete addon URL including port. 
# Examples: 
# http://127.0.0.1:3002, 
# https://my-addon.vercel.app
ADDON_URL=http://localhost:3001

# Logging Configuration - OPTIONAL
# Options: error, warn, info, debug
# error: Only error messages
# warn: Error and warning messages  
# info: Error, warning, and info messages (default)
# debug: All messages including debug output
LOG_LEVEL=info