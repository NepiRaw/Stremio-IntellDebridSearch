# Example environment configuration for Stremio DebridSearch Addon
# Copy this file to .env and fill in your API keys as fallbacks

# Trakt API Key - improves episode matching for non-standard numbering - OPTIONAL
# Get from: https://trakt.tv/oauth/applications
# Example: TRAKT_API_KEY=your_trakt_api_key_here
TRAKT_API_KEY=

# TMDb API Key - enhances title matching for international/alternate titles - OPTIONAL
# Get from: https://developer.themoviedb.org/docs/authentication
# Example: TMDB_API_KEY=your_tmdb_api_key_here
TMDB_API_KEY=

# Variant Detection System - enables detection of content variants (Directors Cut, Extended Edition, etc.) - OPTIONAL
# NB: Not 100% accurate, could be false or misleading if the content is not a variant
# Set to 'false' to disable variant detection if needed
# Default is 'true' to enable variant handling
VARIANT_SYSTEM_ENABLED=false

# Multi-Stream Per Torrent Control - controls stream processing behavior - OPTIONAL
# When 'true': Allows multiple streams per torrent container (a bit slower but could return more results)
# When 'false': Forces single stream per torrent for ultra-fast performance (recommended default)
# Default is 'false' for optimal performance
ENABLE_MULTI_STREAM_PER_TORRENT=false

# Base URL for the addon - OPTIONAL
# Examples with or without domain:
# http://localhost
# https://xyz.com/xxx/yyy
# https://tvdb-addon.xyz.com
BASE_URL=http://localhost

# Server port configuration  - OPTIONAL
PORT=3001

# Logging Configuration - OPTIONAL
# Options: error, warn, info, debug
# error: Only error messages
# warn: Error and warning messages  
# info: Error, warning, and info messages (default)
# debug: All messages including debug output
LOG_LEVEL=info